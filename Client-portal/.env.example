# ══════════════════════════════════════════════════════════════
# BotFlow — Environment Variables
# Copy to .env and fill in real values.
# NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════

# ── Node ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database ──────────────────────────────────────────────────
# Local (docker-compose fills this automatically via service name)
DATABASE_URL=postgres://botflow:changeme@localhost:5432/botflow
POSTGRES_PASSWORD=changeme

# Production (Vercel + Neon / Supabase / Railway)
# DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://:changeme@localhost:6379
REDIS_PASSWORD=changeme

# ── JWT ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_64_RANDOM_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_RANDOM_CHARS

# ── Frontend (Vite) ───────────────────────────────────────────
VITE_API_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:5173

# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── WhatsApp Business API (Meta) ──────────────────────────────
# Get from: developers.facebook.com → Your App → WhatsApp
WHATSAPP_TOKEN=EAA...
WHATSAPP_PHONE_ID=123456789
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_API_URL=https://graph.facebook.com/v19.0

# ── Email (for password reset / notifications) ─────────────────
# Using Resend (recommended): resend.com
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@botflow.io

# ── Vercel (for Vercel CLI / CI deploys) ──────────────────────
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# ── pgAdmin (optional, only with --profile tools) ─────────────
PGADMIN_PASSWORD=admin

# ── Monitoring (optional) ─────────────────────────────────────
SENTRY_DSN=
