{
  "name": "mgucatech-client-portal",
  "version": "1.0.0",
  "private": true,
  "description": "MgucaTECH private client portal",
  "engines": {
    "node": ">=20.0.0",
    "npm":  ">=10.0.0"
  },
  "scripts": {
    "dev":          "concurrently \"npm:dev:api\" \"npm:dev:frontend\"",
    "dev:api":      "node --watch server/index.js",
    "dev:frontend": "vite",
    "build":        "vite build",
    "preview":      "vite preview",
    "start":        "node server/index.js",
    "db:migrate":   "psql $DATABASE_URL -f server/db/schema.sql",
    "db:seed":      "psql $DATABASE_URL -f server/db/seed.sql",
    "db:reset":     "psql $DATABASE_URL -c 'DROP SCHEMA public CASCADE; CREATE SCHEMA public;' && npm run db:migrate && npm run db:seed",
    "test":         "vitest run",
    "test:watch":   "vitest",
    "lint":         "eslint src server --ext .js,.jsx",
    "docker:up":    "docker compose up -d",
    "docker:down":  "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up -d"
  },
  "dependencies": {
    "react":                "^18.3.1",
    "react-dom":            "^18.3.1",
    "recharts":             "^2.12.7",
    "@anthropic-ai/sdk":    "^0.24.0",
    "bcryptjs":             "^2.4.3",
    "cookie-parser":        "^1.4.6",
    "cors":                 "^2.8.5",
    "dotenv":               "^16.4.5",
    "express":              "^4.19.2",
    "express-rate-limit":   "^7.3.1",
    "helmet":               "^7.1.0",
    "jsonwebtoken":         "^9.0.2",
    "pg":                   "^8.12.0",
    "redis":                "^4.6.14"
  },
  "devDependencies": {
    "@types/react":         "^18.3.3",
    "@types/react-dom":     "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently":         "^8.2.2",
    "eslint":               "^9.6.0",
    "vite":                 "^5.3.2",
    "vitest":               "^1.6.0"
  }
}
